{
  "$schema": "https://mintlify.com/docs.json",
  "name": "Cyphers",
  "theme": "linden",
  "logo": {
    "light": "/cypher-logo-light.svg",
    "dark": "/cypher-logo.svg",
    "href": "https://cypher-zk.github.io"
  },
  "icons": {
    "library": "fontawesome"
  },
  "favicon": "/cyphers.png",
  "colors": {
    "primary": "#6d45fc",
    "light": "#A78BFA",
    "dark": "#5B35D5"
  },
  "fonts": {
    "heading": {
      "family": "Open Sans",
      "weight": 700
    },
    "body": {
      "family": "Open Sans",
      "weight": 400
    }
  },
  "appearance": {
    "default": "system"
  },
  "background": {
    "decoration": "windows",
    "color": {
      "light": "#FAF8FF"
    }
  },
  "navbar": {
    "primary": {
      "type": "github",
      "href": "https://github.com/cypher-zk"
    }
  },
  "footer": {
    "socials": {
      "github": "https://github.com/cypher-zk",
      "x": "https://x.com/cypherzk_"
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Get started",
            "icon": "rocket",
            "pages": [
              "introduction",
              "quickstart"
            ]
          },
          {
            "group": "How it works",
            "icon": "cogs",
            "pages": [
              "how-it-works/privacy-model",
              "how-it-works/market-types",
              "how-it-works/lifecycle",
              "how-it-works/fees"
            ]
          },
          {
            "group": "Using Cyphers",
            "icon": "hand-holding-dollar",
            "pages": [
              "guides/place-a-bet",
              "guides/create-a-market",
              "guides/claim-payout",
              "guides/dispute-resolution"
            ]
          },
          {
            "group": "Help",
            "icon": "question-circle",
            "pages": [
              "troubleshooting/faq",
              "troubleshooting/common-errors"
            ]
          }
        ]
      },
      {
        "tab": "SDK Reference",
        "groups": [
          {
            "group": "Get started",
            "icon": "bolt",
            "pages": [
              "sdk/installation",
              "sdk/quickstart"
            ]
          },
          {
            "group": "React",
            "icon": "react",
            "pages": [
              "sdk/react/setup",
              "sdk/react/query-hooks",
              "sdk/react/mutation-hooks"
            ]
          },
          {
            "group": "Actions",
            "icon": "code",
            "pages": [
              "sdk/actions/place-bet",
              "sdk/actions/markets",
              "sdk/actions/resolution",
              "sdk/actions/claims"
            ]
          },
          {
            "group": "Reference",
            "icon": "book",
            "pages": [
              "sdk/reference/client",
              "sdk/reference/accounts",
              "sdk/reference/encryption",
              "sdk/reference/events",
              "sdk/reference/errors",
              "sdk/reference/constants"
            ]
          },
          {
            "group": "Changelog",
            "icon": "clock-rotate-left",
            "pages": [
              "sdk/changelog"
            ]
          }
        ]
      }
    ]
  }
}