{
  "$schema": "https://mintlify.com/docs.json",
  "name": "Cyphers",
  "theme": "luma",
  "logo": {
    "light": "/cyphers.png",
    "dark": "/cyphers.png",
    "href": "https://cypher-zk.github.io"
  },
  "favicon": "/cyphers.png",
  "colors": {
    "primary": "#6d45fc",
    "light": "#b49cfc"
  },
  "appearance": {
    "default": "dark"
  },
  "background": {
    "decoration": "gradient"
  },
  "fonts": {
    "heading": {
      "family": "Inter"
    },
    "body": {
      "family": "Inter"
    }
  },
  "navbar": {
    "primary": {
      "type": "github",
      "href": "https://github.com/cypher-zk"
    }
  },
  "footer": {
    "socials": {
      "github": "https://github.com/cypher-zk"
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Get started",
            "pages": [
              "introduction",
              "quickstart"
            ]
          },
          {
            "group": "How it works",
            "pages": [
              "how-it-works/privacy-model",
              "how-it-works/market-types",
              "how-it-works/lifecycle",
              "how-it-works/fees"
            ]
          },
          {
            "group": "Using Cyphers",
            "pages": [
              "guides/place-a-bet",
              "guides/create-a-market",
              "guides/claim-payout",
              "guides/dispute-resolution"
            ]
          },
          {
            "group": "Help",
            "pages": [
              "troubleshooting/faq",
              "troubleshooting/common-errors"
            ]
          }
        ]
      },
      {
        "tab": "SDK Reference",
        "groups": [
          {
            "group": "Client",
            "pages": [
              "sdk/overview",
              "sdk/cypher-client",
              "sdk/react-hooks"
            ]
          },
          {
            "group": "Actions",
            "pages": [
              "sdk/actions/markets",
              "sdk/actions/bets",
              "sdk/actions/resolution",
              "sdk/actions/claims"
            ]
          },
          {
            "group": "Utilities",
            "pages": [
              "sdk/utilities/market-helpers",
              "sdk/utilities/encryption",
              "sdk/utilities/events"
            ]
          }
        ]
      }
    ]
  }
}
